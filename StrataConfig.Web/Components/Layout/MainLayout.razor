@inherits LayoutComponentBase

<div class="admin-shell">
    <header class="admin-header">
        <div class="brand">
            <span class="brand-title">StrataConfig</span>
            <span class="brand-subtitle">Configuration Studio</span>
        </div>
        <a href="https://learn.microsoft.com/dotnet/" target="_blank" rel="noopener noreferrer">Docs</a>
    </header>

    <main class="admin-body">
        @Body
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
